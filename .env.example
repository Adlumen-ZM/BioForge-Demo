# 复制此文件为 .env 并填入真实值
# cp .env.example .env
DOCKER_IMAGE=bioforge
DOCKER_TAG=local

# LLM API Keys
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_group_id_here

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=bioforge
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=bioforge

# RAG
EMBEDDING_MODEL=BAAI/bge-m3

# LangGraph
LANGGRAPH_CHECKPOINT_DB_URL=postgresql://bioforge:your_password_here@localhost:5432/bioforge

# Langfuse — LLM 全链路追踪（可选）
# 注册 https://cloud.langfuse.com 免费获取 Key（Hobby 档：5万次/月免费）
# 不配置时自动跳过，不影响任何现有功能
# 官方环境变量名（与 Langfuse 文档一致）：
# LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# US 区域用户改为：LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
# 自建实例改为：LANGFUSE_BASE_URL=http://localhost:3000

# Trace MVP — 写入 agent_trace_events 表
# 两种选项（选其一）：
#
# 选项 A：本地开发（无需 Docker，自动在 data/traces.db 创建 SQLite 文件）
TRACE_DB_URL=sqlite:///data/traces.db
#
# 选项 B：生产/CI（PostgreSQL，与业务库同实例同库）
# 若使用 psycopg3 驱动（requirements.txt 中已安装），前缀改为 postgresql+psycopg://
# TRACE_DB_URL=postgresql://bioforge:your_password_here@localhost:5432/bioforge
