# BioForge demo environment template
#
# Usage:
#   1. Copy this file to .env
#   2. Fill every value marked [REQUIRED]
#   3. Keep the /app/... paths when running inside Docker
#
# Notes:
#   - docker run --env-file .env uses these values directly.
#   - docker compose also reads DOCKER_IMAGE/DOCKER_TAG for image naming.
#   - docker-compose.yml may override a few runtime paths through its
#     environment: section; direct docker run does not.


# =============================================================================
# 1. Docker image build/run settings
# =============================================================================

# [REQUIRED for docker compose] Local image name built by docker compose.
DOCKER_IMAGE=bioforge
DOCKER_TAG=demo

# [OPTIONAL] HuggingFace endpoint used during image build to preload BGE-M3.
# Use https://hf-mirror.com only if huggingface.co is slow or blocked.
HF_ENDPOINT=https://huggingface.co

# [OPTIONAL] Torch version installed in the Docker image.
PYTORCH_VERSION=2.12.0


# =============================================================================
# 2. LLM settings used by agents and RAG extraction
# =============================================================================

# [REQUIRED] Main LLM key. The current demo uses LiteLLM/OpenAI-compatible
# clients. For non-OpenAI providers, keep the model prefix as "openai/..." when
# the provider exposes an OpenAI-compatible API.
OPENAI_API_KEY=your_openai_compatible_api_key_here

# [REQUIRED if not using official OpenAI] OpenAI-compatible API base URL.
# Examples:
#   https://api.openai.com/v1
#   https://ark.cn-beijing.volces.com/api/v3
OPENAI_API_BASE=https://your-openai-compatible-endpoint/v1

# [REQUIRED] LiteLLM model string used by guide/search/screen/extract agents.
# Examples:
#   openai/gpt-4o
#   openai/deepseek-v3.2
#   anthropic/claude-3-5-sonnet-20241022
DEFAULT_LLM_MODEL=openai/your-model-name

# [OPTIONAL] RAG service aliases. Leave blank to reuse OPENAI_API_KEY,
# OPENAI_API_BASE, and DEFAULT_LLM_MODEL.
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=

# [OPTIONAL] Legacy/provider-specific keys. Keep only if you intentionally run
# older MiniMax/Anthropic paths.
# MINIMAX_API_KEY=
# MINIMAX_API_KEY_1=
# MINIMAX_API_KEY_2=
# MINIMAX_API_KEY_3=
# MINIMAX_API_KEY_4=
# MINIMAX_GROUP_ID=
# ANTHROPIC_API_KEY=


# =============================================================================
# 3. RAGFlow service settings
# =============================================================================

# [REQUIRED for RAG extraction] RAGFlow base URL. Do not append /api/v1 because
# the code appends /api/v1 internally.
RAGFLOW_API_BASE_URL=https://ragflow.adlumen.top

# [REQUIRED for RAG extraction] RAGFlow API key.
RAGFLOW_API_KEY=ragflow-xxxxxxxxxxxxxxxx

# [OPTIONAL] RAGFlow parsing method and polling timeout. Large PDFs may need a
# higher timeout or pre-compressed images.
RAGFLOW_CHUNK_METHOD=paper
RAGFLOW_POLL_TIMEOUT_SEC=600


# =============================================================================
# 4. NCBI / PubMed search and PDF download
# =============================================================================

# [STRONGLY RECOMMENDED] NCBI asks tools to provide an email for API access.
NCBI_EMAIL=your_email@example.com

# [OPTIONAL] Improves PubMed API rate limits.
NCBI_API_KEY=your_ncbi_api_key_here

# [OPTIONAL] Per-request PDF download timeout in seconds.
DOWNLOAD_PDF_TIMEOUT_S=30


# =============================================================================
# 5. Runtime mode, data paths, and business database
# =============================================================================

# [RECOMMENDED] Agent mode. Defaults to demo/mock in code paths, but setting it
# explicitly makes runs easier to reason about.
GRAPH_AGENT_MODE=demo

# [RECOMMENDED in Docker] Root directory for project data, traces, downloaded
# PDFs, RAG CSV outputs, and SQLite DB files. Docker images default to /app/data.
DATA_ROOT=/app/data

# [RECOMMENDED] Extraction profile. Defaults to hap_peptide_v1 in the demo and
# must match a schema template directory under docs/schema_templates/.
EXTRACTION_PROFILE=hap_peptide_v1

# [RECOMMENDED] Business SQLite database path used by direct docker run.
# Docker images default to /app/data/hap_v01.db. If you use docker compose,
# docker-compose.yml may override this path.
BIZ_DB_PATH=/app/data/hap_v01.db

# [OPTIONAL] Future/PostgreSQL business DB path. If set, system_check displays
# DATABASE_URL instead of BIZ_DB_PATH, but the current demo write path is SQLite.
# DATABASE_URL=postgresql://bioforge:your_password@postgres:5432/bioforge

# [OPTIONAL] Legacy/development Postgres component fields. Current demo code
# does not read these directly; keep them only for local scripts or future DB
# deployment templates.
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=bioforge
# POSTGRES_PASSWORD=your_password_here
# POSTGRES_DB=bioforge

# [OPTIONAL] Future LangGraph persistent checkpoint DB. The current CLI demo
# uses an in-memory checkpointer, so this is not required.
# LANGGRAPH_CHECKPOINT_DB_URL=postgresql://bioforge:your_password@localhost:5432/bioforge


# =============================================================================
# 6. BGE-M3 embedding and retrieval
# =============================================================================

# [OPTIONAL] Runtime HuggingFace cache paths. The Docker image preloads BGE-M3
# into /hf_cache; do not mount an empty host directory over /hf_cache unless you
# want to manage the cache yourself.
HF_HOME=/hf_cache
HUGGINGFACE_HUB_CACHE=/hf_cache/hub
TRANSFORMERS_CACHE=/hf_cache/hub

# [OPTIONAL] BGE model path or HuggingFace model id.
BGE_MODEL_DIR=BAAI/bge-m3

# [OPTIONAL] Compatibility alias; BGE_MODEL_DIR takes priority.
EMBEDDING_MODEL=BAAI/bge-m3

# [OPTIONAL] Keep false on CPU. Enable only when your runtime supports fp16 well.
BGE_USE_FP16=false

# [OPTIONAL] Retrieval controls for local RAG evidence search.
RETRIEVAL_TOP_K=8
RETRIEVAL_THRESHOLD=0.1

# [OPTIONAL] Keep false to use the lightweight in-memory collection adapter.
RAG_USE_CHROMADB=false

# [OPTIONAL] Limits how many candidate entities RAG extracts per paper.
RAG_MAX_ENTITIES_PER_PAPER=3

# [OPTIONAL] Timeout for RAG LLM calls.
LLM_TIMEOUT_SEC=120


# =============================================================================
# 7. Trace and CLI diagnostics
# =============================================================================

# [OPTIONAL] Master switch for trace events.
TRACE_ENABLED=true

# [OPTIONAL] Write data/runs/{date}/{run_id}/trace/events.jsonl.
TRACE_FILE_ENABLED=true

# [OPTIONAL] Stream trace events into the CLI progress panel.
TRACE_CLI_ENABLED=true

# [OPTIONAL] CLI trace verbosity: quiet / normal / debug.
TRACE_CLI_LEVEL=normal

# [OPTIONAL] Trace run output root inside the container.
TRACE_DATA_ROOT=/app/data/runs

# [OPTIONAL] Maximum stored payload length per trace event.
TRACE_MAX_PAYLOAD_CHARS=4000

# [OPTIONAL] Legacy SQLite trace path used by older trace helpers.
TRACE_DB_PATH=/app/data/hap_trace.db

# [OPTIONAL] PostgreSQL trace backend. Leave blank for file-based demo traces.
# TRACE_DB_URL=postgresql://bioforge:your_password@postgres:5432/bioforge

# [OPTIONAL] Langfuse tracing placeholders. The current demo does not require
# Langfuse; leave these blank unless you wire a Langfuse backend/client.
# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com


# =============================================================================
# 8. Schema overrides for advanced debugging
# =============================================================================

# [OPTIONAL] Explicit schema.yaml path. Leave blank to use:
# docs/schema_templates/${EXTRACTION_PROFILE}/schema.yaml
SCHEMA_TEMPLATE_PATH=

# [OPTIONAL] Explicit field mapping file. Leave blank to use schema.yaml.
FIELD_MAPPING_PATH=
