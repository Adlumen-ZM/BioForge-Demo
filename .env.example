# cp .env.example .env  then fill in real values
DOCKER_IMAGE=bioforge
DOCKER_TAG=local

# LLM API Keys
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_group_id_here

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=bioforge
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=bioforge

# RAG
EMBEDDING_MODEL=BAAI/bge-m3

# LangGraph
LANGGRAPH_CHECKPOINT_DB_URL=postgresql://bioforge:your_password_here@localhost:5432/bioforge

# NCBI
NCBI_API_KEY=your_ncbi_api_key_here
NCBI_EMAIL=your_ncbi_email_here

# =========================
# PepClaw RAG Integration
# =========================

# RAGFlow（视觉 PDF 解析服务）
RAGFLOW_API_BASE_URL=https://your-ragflow-host
RAGFLOW_API_KEY=ragflow-xxxxxxxxxxxxxxxx

# LLM / OpenAI-compatible API（用于 Scout 盲盒发现 & Strike 字段抽取）
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
LLM_MODEL=ark-code-latest
LLM_TEMPERATURE=0

# BGE-M3 Embedding（混合检索，首次加载需下载模型约 2GB）
BGE_MODEL_DIR=BAAI/bge-m3
BGE_USE_FP16=false
BGE_DENSE_WEIGHT=0.4
BGE_SPARSE_WEIGHT=0.6

# Retrieval 参数
RETRIEVAL_TOP_K=8
RETRIEVAL_THRESHOLD=0.1

# =========================
# Trace MVP（v0.1）
# =========================
# 总开关
TRACE_ENABLED=true

# 是否写 data/runs/{date}/{run_id}/trace/events.jsonl
TRACE_FILE_ENABLED=true

# 是否向 CLI 进度面板推送日志行
TRACE_CLI_ENABLED=true

# CLI 日志级别：quiet / normal / debug
TRACE_CLI_LEVEL=normal

# Trace 文件根目录（容器内路径）
TRACE_DATA_ROOT=/app/data/runs

# 单个 payload 最大字符数（超出截断）
TRACE_MAX_PAYLOAD_CHARS=4000

# 是否保存 LLM 原始输出到 operator_debug/（默认 false，避免存大文件）
TRACE_SAVE_RAW_LLM_OUTPUT=false

# 运行模式（demo 模式 guide agent 正常调用 LLM，search/screen/extract 使用 mock）
GRAPH_AGENT_MODE=demo
